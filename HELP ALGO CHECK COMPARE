public boolean hasFullFamily(PropertyCard cardToCheck) {
    String family = cardToCheck.getFamilyGroup();
    int required = cardToCheck.getTotalInFamily();

    // On compte combien de cartes de cette famille le joueur possède
    long count = this.ownedProperties.stream()
            .filter(p -> p.getFamilyGroup().equals(family))
            .count();

    return count == required;
}
