    private ArrayList<Propriete> mesProprietes;
    private Map<String, Integer> familleCompteur;

    public Joueur(String nom) {
        this.nom = nom;
        this.mesProprietes = new ArrayList<>();
        this.familleCompteur = new HashMap<>(); // On commence VIDE
    }

